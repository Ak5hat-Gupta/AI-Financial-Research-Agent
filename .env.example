# ============================================================
#  AI Financial Research Agent — Environment Configuration
#  Copy to `.env` and fill in. Everything works in DEMO MODE
#  even with no API keys set (deterministic fallbacks).
# ============================================================

# ---- App ----
APP_NAME="AI Financial Research Agent"
ENVIRONMENT=development          # development | production
DEBUG=true
API_V1_PREFIX=/api

# ---- Security (CHANGE THIS IN PRODUCTION) ----
# Generate one with:  openssl rand -hex 32
SECRET_KEY=change-me-please-generate-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ---- Database ----
# Local dev defaults to SQLite (no setup needed).
# For Postgres / Docker, use the line below instead.
DATABASE_URL=sqlite:///./financial_agent.db
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/financial_agent

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

# ---- LLM provider ----
# provider: anthropic | openai | demo  (demo = no key required)
LLM_PROVIDER=demo
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Market & news data (optional) ----
# yfinance needs no key. NewsAPI is optional; falls back to sample data.
NEWSAPI_KEY=

# ---- File uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

# ---- Frontend (Vite reads VITE_ prefixed vars) ----
VITE_API_URL=http://localhost:8000

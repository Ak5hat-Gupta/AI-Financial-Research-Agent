# ============================================================
#  Atlas — Environment Configuration
#  Copy to `.env` and fill in. Everything works in DEMO MODE
#  even with no API keys or external services (deterministic fallbacks).
# ============================================================

# ---- App ----
APP_NAME=Atlas
ENVIRONMENT=development          # development | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Security (CHANGE THIS IN PRODUCTION) ----
# Generate one with:  openssl rand -hex 32
SECRET_KEY=change-me-please-generate-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ---- OAuth (optional; auto-enabled when client id + secret are present) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# ---- Database ----
# Local dev defaults to SQLite (no setup needed).
# For Postgres / Docker, use the line below instead.
DATABASE_URL=sqlite:///./atlas.db
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/atlas

# ---- Cache / sessions (optional; falls back to in-process cache) ----
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# ---- Knowledge graph & vector store (Phase 3; optional) ----
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
QDRANT_URL=

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ---- LLM provider ----
# provider: anthropic | openai | demo  (demo = no key required)
LLM_PROVIDER=demo
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Market & news data (optional) ----
# yfinance needs no key. NewsAPI is optional; falls back to sample data.
NEWSAPI_KEY=

# ---- File uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

# ---- Observability ----
LOG_LEVEL=INFO
LOG_JSON=true

# ---- Rate limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# ---- Frontend ----
# Next.js (Phase 1) reads NEXT_PUBLIC_API_URL; legacy Vite client reads VITE_API_URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
